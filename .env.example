DATABASE_URL=postgresql://crowdship:change-me@127.0.0.1:5432/crowdship
REQUIRE_DATABASE=1
OPENAI_API_KEY=replace-me
OPENAI_INTAKE_MODEL=gpt-5.4
OPENAI_COMPLETION_MODEL=gpt-5.4
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
CROWDSHIP_WORKER_POLL_MS=15000
EXAMPLE_REPO_PATH=/root/example
EXAMPLE_REPOSITORY_FULL_NAME=aizenshtat/example
EXAMPLE_DEFAULT_BRANCH=main
# The worker invokes this helper from EXAMPLE_REPO_PATH and passes the contribution id.
EXAMPLE_PREVIEW_DEPLOY_SCRIPT=/root/example/scripts/deploy-preview.sh
CROWDSHIP_BASE_URL=https://crowdship.aizenshtat.eu
EXAMPLE_BASE_URL=https://example.aizenshtat.eu
ATTACHMENT_STORAGE_DIR=/var/lib/crowdship/attachments
ATTACHMENT_MAX_BYTES=26214400
DEMO_VIDEO_STORAGE_DIR=/var/lib/crowdship/demo-video
DEMO_VIDEO_UPLOAD_TOKEN=replace-me
DEMO_VIDEO_MAX_BYTES=734003200
