{
  "name": "crowdship",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api": "node src/server/http.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "quality": "bash scripts/quality-check.sh",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && bash -n scripts/*.sh .githooks/pre-commit"
  },
  "dependencies": {
    "@sentry/browser": "^10.49.0",
    "@sentry/node": "^10.49.0",
    "@types/pg": "^8.20.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
